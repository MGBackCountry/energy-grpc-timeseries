FROM redis:7-alpine

LABEL maintainer="gertjan"

# Expose Redis default port
EXPOSE 6379

# Persist data
VOLUME ["/data"]

# The official Redis image already provides a solid default CMD (redis-server)
# Add a simple healthcheck so orchestrators know when Redis is ready
HEALTHCHECK --interval=30s --timeout=3s --start-period=15s \
  CMD redis-cli ping || exit 1

